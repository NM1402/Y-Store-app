{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "yarn install --frozen-lockfile",
  "buildCommand": "CI=false NODE_OPTIONS=--max_old_space_size=4096 yarn build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
