# ==========================================================================
# Y-STORE TELEGRAM MINI APP — BACKEND ENVIRONMENT VARIABLES
# ==========================================================================
# Скопіюйте цей файл у backend/.env і заповніть реальні ключі
# (усі робочі ключі — у docs/03_INTEGRATION_KEYS.md)
# ==========================================================================

# ---------- MongoDB ----------
MONGO_URL="mongodb://localhost:27017"
DB_NAME="tma_store"

# ---------- CORS ----------
# У production замінити на "https://y-store.in.ua,https://tma.y-store.in.ua"
CORS_ORIGINS="*"

# ---------- Telegram Bot ----------
# Бот: @Ystore_app_bot (id 8524617770, name "Y-STORE App")
TELEGRAM_BOT_TOKEN="8524617770:AAECLj0A8wTjg3cy-KxYcIkvlK4HE3VROqY"
# URL вашого TMA (замінити на свій домен!)
TMA_URL="https://tma.y-store.in.ua/tma"
APP_URL="https://tma.y-store.in.ua"
# 0 — production (перевірка Telegram initData обов'язкова)
# 1 — dev (дозволяє sandbox:<id> як валідний initData)
TMA_ALLOW_SANDBOX="0"

# ---------- Nova Poshta ----------
# API ключ від sender-аккаунту (ФОП ТИЩЕНКО ОЛЕКСАНДР МИКОЛАЙОВИЧ)
NOVAPOSHTA_API_KEY="5cb1e3ebc23e75d737fd57c1e056ecc9"
NP_API_KEY="5cb1e3ebc23e75d737fd57c1e056ecc9"

# Відправник (усі Ref взяті з профілю НП, документи/рахунки на ФОП)
NP_SENDER_NAME="Y-Store"
NP_SENDER_PHONE="380637247703"
NP_SENDER_COUNTERPARTY_REF="07f0c105-442e-11ea-8133-005056881c6b"
NP_SENDER_CONTACT_REF="4deeee78-44d2-11ea-8133-005056881c6b"
NP_SENDER_CITY_REF="8d5a980d-391c-11dd-90d9-001a92567626"           # Київ
NP_SENDER_WAREHOUSE_REF="1ec09d88-e1c2-11e3-8c4a-0050568002cf"      # Відділення №1

# ---------- WayForPay ----------
# Мерчант: y_store_in_ua
WAYFORPAY_MERCHANT_ACCOUNT="y_store_in_ua"
WAYFORPAY_MERCHANT_SECRET="4f27e43c7052b31c5df78863e0119b51b1e406ef"
WAYFORPAY_MERCHANT_PASSWORD="a6fcf5fe2a413bdd25bb8b2e7100663a"
WAYFORPAY_MERCHANT_DOMAIN="y-store.in.ua"
# URLs — замінити на свій домен
WAYFORPAY_RETURN_URL="https://tma.y-store.in.ua/tma/order-success"
WAYFORPAY_SERVICE_URL="https://tma.y-store.in.ua/api/v2/payments/wayforpay/webhook"

# ---------- JWT (для майбутнього переходу з UUID-sessions на підписані JWT) ----------
# Згенерувати: openssl rand -hex 32
JWT_SECRET_KEY="CHANGE_ME_openssl_rand_hex_32"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_DAYS="7"

# ==========================================================================
# SITE INTEGRATION — заповнюється КОЛИ підключаєте каталог сайту
# (до тих пір TMA працює на локальному seed з 20 товарів)
# ==========================================================================

# 0 — TMA читає каталог з локального MongoDB seed (default)
# 1 — TMA проксує запити каталогу через site_adapter.py до бекенду сайту
SITE_ADAPTER_ENABLED="0"

# URL до REST API основного сайту y-store.in.ua
# Приклади: https://api.y-store.in.ua, https://y-store.in.ua/api/v1
SITE_API_URL=""

# Service-to-service токен (згенерувати в адмінці сайту)
# Використовується у header: Authorization: Bearer <token>
SITE_API_TOKEN=""

# (опційно) HMAC-секрет для вхідних webhook'ів від сайту
# (якщо сайт пушить оновлення товарів у TMA)
SITE_WEBHOOK_SECRET=""
